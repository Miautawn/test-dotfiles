hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1

###################
# GLOBAL SETTINGS #
###################

ACTIVE_TAB_COLOUR="#98c379"
INACTIVE_TAB_COLOUR="#262626"
HIGHLIGHT_LINE_COLOUR="#D8D8D8"
INACTIVE_HIGHLIGHT_COLOUR="#808080"

# GLOBAL BOARDER SETTINGS
hc attr theme.border_width        0
hc attr theme.normal.border_width 0

#hc attr theme.padding_top 2
hc attr theme.padding_left 2
hc attr theme.padding_right 2
hc attr theme.padding_bottom 2

hc attr theme.outer_width        2
hc attr theme.normal.outer_width 2
hc attr theme.active.outer_color $HIGHLIGHT_LINE_COLOUR   # outer bar colour on focused windows (incluidng tabs)
hc attr theme.normal.outer_color $INACTIVE_TAB_COLOUR     # outer bar colour on unfocused windows (including tabs)

# GLOBAL TAB SETTINGS
# https://github.com/herbstluftwm/herbstluftwm/discussions/1520
hc attr theme.active.color $INACTIVE_TAB_COLOUR           # focused tab color in the focused client
hc attr theme.active.tab_color $INACTIVE_TAB_COLOUR       # unfocused tab color in the focused client
hc attr theme.normal.color $INACTIVE_TAB_COLOUR         # focused tab color in the unfocused client

# GLOBAL TITLE SETTINGS
hc attr theme.title_font  '0xProto Nerd Font Mono:pixelsize=12'
hc attr theme.title_align center
hc attr theme.title_height 13
hc attr theme.title_depth 3
hc attr theme.title_when "always"
hc attr theme.active.title_color $ACTIVE_TAB_COLOUR
hc attr theme.normal.title_color $INACTIVE_HIGHLIGHT_COLOUR

# GLOBAL FRAME SETTINGS
hc set show_frame_decorations 'none'
hc set frame_border_width 0
hc set frame_bg_transparent on
hc set frame_transparent_width 0
hc set frame_gap 0
hc set frame_padding 0

hc set frame_border_active_color '#D8D8D8'
hc set frame_bg_active_color '#D8D8D8'
hc set frame_border_normal_color '#1e222a'
hc set frame_bg_normal_color '#1e222a'

# GLOBAL MISCELANIOUS
hc set window_gap 15
hc set smart_window_surroundings off
hc set smart_frame_surroundings off
hc set mouse_recenter_gap 0
hc set hide_covered_windows true

