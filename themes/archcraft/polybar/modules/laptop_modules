##################
# LAPTOP MODULES #
##################

[module/battery]
type = internal/battery

; This is useful in case the battery never reports 100% charge
full-at = 99
low_at = 10

; Use the following command to list batteries and adapters:
; $ ls -1 /sys/class/power_supply/
; you can leave it undefined and polybar will attempt to find defaults
;battery = BAT0
;adapter = AC
poll-interval = 1

; Available tags:
;   <label-charging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-charging>
format-charging = <label-charging>
format-charging-prefix = "󰂄 "
format-charging-prefix-font = 1
format-charging-background = ${colors.BLACK}
format-charging-foreground = ${colors.FOREGROUND}

; Available tags:
;   <label-discharging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-discharging>
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-background = ${colors.BLACK}
format-discharging-foreground = ${colors.FOREGROUND}

; Available tokens:
;   %percentage% (default)
format-low = <label-low>
format-low-prefix = "󱟩 "
format-low-prefix-font = 1

format-full = <label-full>
format-full-prefix = "󰁹 "
format-full-prefix-font = 1
format-full-background = ${colors.BLACK}
format-full-foreground = ${colors.FOREGROUND}

label-charging = %percentage%%
label-discharging = %percentage%%
label-low = %percentage%%
label-full = %percentage%%

; Only applies if <ramp-capacity> is used
ramp-capacity-0 = 󰁺
ramp-capacity-1 = 󰁻
ramp-capacity-2 = 󰁼
ramp-capacity-3 = 󰁽
ramp-capacity-4 = 󰁾
ramp-capacity-5 = 󰁿
ramp-capacity-6 = 󰂀
ramp-capacity-7 = 󰂁
ramp-capacity-8 = 󰂂
ramp-capacity-9 = 󰁹
ramp-capacity-font = 1
##################

[module/network]
type = internal/network

interface = wlan0
interface-type = wireless

interval = 3
; NOTE: Experimental (might change or be removed in the future)
ping-interval = 3

accumulate-stats = false
unknown-as-up = true

format-connected = %{A3:$HOME/.local/bin/wifi_panel &:}<ramp-signal>%{A}
format-connected-foreground = ${colors.FOREGROUND}
format-connected-background = ${colors.BLACK}
ramp-signal-0 = 󰤯
ramp-signal-1 = 󰤟
ramp-signal-2 = 󰤢
ramp-signal-3 = 󰤥
ramp-signal-4 = 󰤨
ramp-signal-font = 2

format-disconnected = %{A3:$HOME/.local/bin/wifi_panel &:}<label-disconnected>%{A}
format-disconnected-foreground = ${colors.FOREGROUND}
format-disconnected-background = ${colors.BLACK}
label-disconnected = "󰤮"
label-disconnected-font = 2

format-packetloss = %{A3:$HOME/.local/bin/wifi_panel &:}<label-packetloss>%{A}
format-packetloss-foreground = ${colors.FOREGROUND}
format-packetloss-background = ${colors.BLACK}
label-packetloss = "󰤫"
label-packetloss-font = 2

##################

[module/bluetooth]
type = custom/script

# Check if any bluetooth devices are currently connected
exec = sh -c 'if [ -n "$(bluetoothctl devices Connected)" ]; then echo ""; else echo ""; fi'

# Refresh every 3 seconds to stay lightweight
interval = 3

format-foreground = ${colors.FOREGROUND}
format-background = ${colors.BLACK}
format-font = 1

click-right = $HOME/.local/bin/bluetooth_panel
