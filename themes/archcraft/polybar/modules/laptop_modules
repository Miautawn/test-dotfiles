##################
# LAPTOP MODULES #
##################

[module/battery]
type = internal/battery

; This is useful in case the battery never reports 100% charge
full-at = 99
low_at = 10

; Use the following command to list batteries and adapters:
; $ ls -1 /sys/class/power_supply/
; you can leave it undefined and polybar will attempt to find defaults
;battery = BAT0
;adapter = AC
poll-interval = 1

; Available tags:
;   <label-charging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-charging>
format-charging = <label-charging>
format-charging-prefix = "َ°‚„ "
format-charging-prefix-font = 1
format-charging-background = ${colors.BLACK}
format-charging-foreground = ${colors.FOREGROUND}

; Available tags:
;   <label-discharging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-discharging>
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-background = ${colors.BLACK}
format-discharging-foreground = ${colors.FOREGROUND}

; Available tokens:
;   %percentage% (default)
format-low = <label-low>
format-low-prefix = "َ±ں© "
format-low-prefix-font = 1

format-full = <label-full>
format-full-prefix = "َ°پ¹ "
format-full-prefix-font = 1
format-full-background = ${colors.BLACK}
format-full-foreground = ${colors.FOREGROUND}

label-charging = %percentage%%
label-discharging = %percentage%%
label-low = %percentage%%
label-full = %percentage%%

