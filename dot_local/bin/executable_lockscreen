#!/usr/bin/env bash

env \
  XSECURELOCK_AUTHPROTO=authproto_pam \
  XSECURELOCK_SAVER=saver_blank \
  XSECURELOCK_PASSWORD_PROMPT=cursor \
  XSECURELOCK_FONT="0xProto Nerd Font Mono:style=Regular" \
  XSECURELOCK_BLANK_TIMEOUT=30 \
  XSECURELOCK_AUTH_TIMEOUT=10 \
  XSECURELOCK_BURNIN_MITIGATION=0 \
  XSECURELOCK_AUTH_FOREGROUND_COLOR=#D8D8D8 \
  XSECURELOCK_AUTH_BACKGROUND_COLOR=#87A181 \
  XSECURELOCK_SAVER_RESET_ON_AUTH_CLOSE=1 \
  XSECURELOCK_SAVER_STOP_ON_BLANK=1 \
  XSECURELOCK_SINGLE_AUTH_WINDOW=1 \
  xsecurelock