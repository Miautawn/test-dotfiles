#!/usr/bin/env bash

# -----------------------------------------------------------------------------
# Fast herbstluftwm window switcher
#
# Features:
#   - Windows grouped by tag
#   - Current window preselected
#   - Urgent windows highlighted
#   - Uses chain to reduce herbstclient IPC calls
# -----------------------------------------------------------------------------

set -euo pipefail

active_win=$(herbstclient attr clients.focus.winid 2>/dev/null || true)

# -----------------------------------------------------------------------------
# Batch 1:
# Collect all windows and their tags
#
# We create one big command:
#
# chain ,
#     echo @@TAG:web ,
#     list_clients --tag=web,
#     echo @@TAG:code ,
#     list_clients --tag=code
#
# Instead of one herbstclient invocation per tag.
# -----------------------------------------------------------------------------

mapfile -t tags < <(
    herbstclient complete 1 use
)

chain=(chain ,)
first=true
for tag in "${tags[@]}"; do
    if ! $first; then
        chain+=(,)
    fi
    first=false

    chain+=(
        echo "@@TAG:$tag"
        ,
        list_clients "--tag=$tag"
    )
done

clients_output=$(herbstclient "${chain[@]}")

# -----------------------------------------------------------------------------
# Parse client list
# -----------------------------------------------------------------------------

window_ids=()
window_tags=()
current_tag=""

while IFS= read -r line; do

    case "$line" in

        @@TAG:*)
            current_tag="${line#@@TAG:}"
            ;;

        "")
            ;;

        *)
            window_ids+=("$line")
            window_tags+=("$current_tag")
            ;;

    esac

done <<< "$clients_output"

# do nothing if there are not clients
if [[ ${#window_ids[@]} == 0 ]]; then
    exit 0
fi

# -----------------------------------------------------------------------------
# Batch 2:
# Retrieve class + urgency
# -----------------------------------------------------------------------------

chain=(chain ,)
first=true
for win_id in "${window_ids[@]}"; do

    if ! $first; then
        chain+=(,)
    fi
    first=false

    chain+=(
        sprintf STR %s\|%s\|%s
        clients.$win_id.class
        clients.$win_id.title
        clients.$win_id.urgent
        echo STR
    )
done

attrs_output=$(herbstclient "${chain[@]}")

# -----------------------------------------------------------------------------
# Parse attributes
#
# We split on @@END@@ because classes can contain spaces.
# -----------------------------------------------------------------------------

classes=()
titles=()
urgent_rows=()

max_class_length=0
selected_row=0
i=0

while IFS=$'\|' read -r class title urgent; do

    classes+=("${class:-Some Window}")
    titles+=("${title:-Some Title}")

    if [[ $urgent == "true" ]]; then
        urgent_rows+=("$i")
    fi

    if [[ "${window_ids[$i]}" == "$active_win" ]]; then
        selected_row="$i"
    fi

    if [[ ${#class} -gt $max_class_length ]]; then
        max_class_length=${#class}
    fi

    ((i+=1))

done <<< "$attrs_output"

menu_lines=()
for i in "${!window_ids[@]}"; do
    printf -v formatted_line "[%s] %-${max_class_length}s · %s" \
        "${window_tags[$i]}" "${classes[$i]}" "${titles[$i]}"
    
    menu_lines+=("$formatted_line")
done

# -----------------------------------------------------------------------------
# Rofi
# -----------------------------------------------------------------------------

rofi_flags=(
    -dmenu
    -i
    -format i
    -theme window_theme
)

if [[ -n "$active_win" ]]; then
    rofi_flags+=(
        -selected-row "$selected_row"
        -a "$selected_row"
    )
fi


if ((${#urgent_rows[@]})); then
    IFS=,
    rofi_flags+=(-u "${urgent_rows[*]}")
    unset IFS
fi


choice=$(
    printf '%s\n' "${menu_lines[@]}" |
    rofi "${rofi_flags[@]}"
)


if [[ -z "$choice" || "$choice" == "-1" ]]; then
    exit 0
fi

herbstclient jumpto "${window_ids[$choice]}"